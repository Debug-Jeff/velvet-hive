{
  "name": "velvet-hive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently -n CLIENT,SERVER -c blue,green \"npm run dev\" \"npm run dev:server\"",
    "dev:split": "powershell -ExecutionPolicy Bypass -File scripts/dev-split.ps1",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/react": "^10.64.0",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.400.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^18.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^5.0.2",
    "vite": "^8.1.3"
  }
}
