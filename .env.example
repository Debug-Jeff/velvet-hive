# Optional - error tracking is simply disabled if left blank
VITE_SENTRY_DSN=

# Cloud name only (not a secret) - used to route product image URLs through
# Cloudinary's fetch delivery for CDN caching + auto format/quality
VITE_CLOUDINARY_CLOUD_NAME=

# Site key only (not a secret, safe to expose client-side). Defaults to
# Cloudflare's official always-pass test key if left blank - fine for local
# dev, but provides zero real protection in production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
