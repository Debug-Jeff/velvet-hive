DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce_db?schema=public"
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
APP_NAME="Velvet Hive"

JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_PEPPER=change-me-to-a-different-long-random-string

SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-me

# --- Daraja (M-Pesa) ---
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
# Safaricom's published sandbox test Shortcode + Passkey - fine until you go live
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=vyub7b77nyom90n9v86677c8587ki8v68bny89m
# Must be a public HTTPS URL - use an ngrok tunnel locally, or your Render URL once deployed
DARAJA_CALLBACK_BASE_URL=https://changeme.example.com

# --- Paystack ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Google OAuth (Sign in with Google) ---
# From a Google Cloud OAuth 2.0 Client (Web application) - the redirect URI below
# must be registered as an authorized redirect URI on that client. Must go
# through the frontend's origin (proxy in dev, Render rewrite in prod), not
# straight to the backend - see the long comment in this same spot in
# server/.env for why (cookie-scoping across the two origins).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# --- Cloudinary (media storage) ---
# From https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Sentry (error tracking) - optional, disabled if left blank ---
SENTRY_DSN=

# --- Cloudflare Turnstile (bot protection on register/login/forgot-password) ---
# From https://dash.cloudflare.com -> Turnstile. Defaults to Cloudflare's
# official always-pass test secret if left blank - fine for local dev, but
# provides zero real protection in production.
TURNSTILE_SECRET_KEY=

# --- Email (Nodemailer / SMTP) ---
# Point at a local Mailpit container for dev (docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Velvet Hive <no-reply@velvethive.test>"
SMTP_SECURE=false
